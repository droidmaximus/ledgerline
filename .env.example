# ============================================================================
# Copy to .env and fill in secrets:  cp .env.example .env
# Ledgerline — local defaults align with docker/docker-compose.yml (MinIO, Postgres).
# ============================================================================

# ============================================================================
# AWS Configuration (for production) or MinIO (for local development)
# ============================================================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Must match buckets created by MinIO init in docker/docker-compose.yml
S3_BUCKET_DOCUMENTS=pageindex-documents-dev
S3_BUCKET_TREES=pageindex-trees-dev
S3_ENDPOINT_URL=http://localhost:9000

# ============================================================================
# Kafka Configuration
# ============================================================================

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_INGESTED=documents.ingested
KAFKA_TOPIC_PARSED=documents.parsed
KAFKA_TOPIC_QUERIES=queries.completed
KAFKA_GROUP_PARSER=parser-service
KAFKA_GROUP_CACHE=cache-service
KAFKA_GROUP_EVAL=evaluation-service

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# ============================================================================
# Claude API (Anthropic) — primary LLM path for gateway, parser, evaluation
# https://console.anthropic.com/
# ============================================================================

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ============================================================================
# Service Ports
# ============================================================================

INGESTION_SERVICE_PORT=8080
PARSER_SERVICE_PORT=8081
CACHE_SERVICE_PORT=8082
API_GATEWAY_PORT=8083
EVALUATION_SERVICE_PORT=8084

# ============================================================================
# Service URLs
# ============================================================================

CACHE_SERVICE_URL=http://localhost:8082
API_GATEWAY_URL=http://localhost:8083
PARSER_SERVICE_URL=http://localhost:8081
# Optional overrides (Go gateway defaults match local ports above)
# INGESTION_SERVICE_URL=http://localhost:8080
# EVALUATION_SERVICE_URL=http://localhost:8084

# ============================================================================
# Logging & Debugging
# ============================================================================

LOG_LEVEL=info
LOG_FORMAT=json
DEBUG=false
HTTP_LOG_VERBOSE=false

# ============================================================================
# Database (evaluation-service) — Docker Compose maps Postgres to host 5433
# ============================================================================

DATABASE_URL=postgresql+asyncpg://pageindex:pageindex_password@localhost:5433/pageindex_eval

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=pageindex
POSTGRES_PASSWORD=pageindex_password
POSTGRES_DB=pageindex_eval

# ============================================================================
# Security & rate limiting / CORS
# ============================================================================

RATE_LIMIT=100
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=application/pdf
# Frontend (3000), ingestion (8080), alternate dev (8000)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

RATE_LIMIT_PER_MINUTE=100
WEBSOCKET_TIMEOUT_SECONDS=300

# ============================================================================
# Observability
# ============================================================================

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ============================================================================
# Parser — PageIndex tree generation options
# ============================================================================

PAGEINDEX_ADD_NODE_SUMMARY=yes
PAGEINDEX_ADD_DOC_DESCRIPTION=yes
PAGEINDEX_ADD_NODE_ID=yes
PAGEINDEX_MAX_PAGES_PER_NODE=10
PAGEINDEX_MAX_TOKENS_PER_NODE=20000

# Optional: OpenAI-compatible / CHATGPT_API_KEY path for PageIndex OSS (parser only)
# OPENAI_API_KEY=
# CHATGPT_API_KEY=
# OPENAI_BASE_URL=
# PAGEINDEX_MODEL=gpt-4o-mini

# ============================================================================
# Development
# ============================================================================

ENVIRONMENT=development

# ============================================================================
# Setup notes
# ============================================================================
# - MinIO local user/password: minioadmin / minioadmin (see compose)
# - Set CLAUDE_API_KEY before running gateway, parser, or evaluation-service
# - S3 bucket names must match the mc mb ... names in docker-compose or uploads fail
# - Production: use IAM / Secrets Manager; do not commit .env
